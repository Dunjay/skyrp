# Backend API
# Base URL of the SkyRP backend server.
# The launcher fetches the server list, modlist, news, and client files from here.
# Change this to your production URL when building a release.
API_URL=https://api.skyrimroleplay.co.uk

# Nexus Mods login. OAuth is preferred when a client id is set; the older
# websocket SSO is the fallback when only the application slug is set.
# The callback URL to register with the Nexus team is:
#   http://127.0.0.1:48521/nexus/callback   (port = NEXUS_OAUTH_PORT)
NEXUS_OAUTH_CLIENT_ID=
NEXUS_OAUTH_PORT=48521
NEXUS_APP_SLUG=
